{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "User account information and wallet balance",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "username": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "admin"] },
        "walletBalance": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "username", "role", "walletBalance", "createdAt"]
    },
    "Service": {
      "title": "Service",
      "description": "SMM service details",
      "type": "object",
      "properties": {
        "growwServiceId": { "type": "integer" },
        "name": { "type": "string" },
        "category": { "type": "string" },
        "platform": { "type": "string" },
        "type": { "type": "string" },
        "providerRate": { "type": "number" },
        "displayRate": { "type": "number" },
        "minQuantity": { "type": "integer" },
        "maxQuantity": { "type": "integer" },
        "refill": { "type": "boolean" },
        "cancel": { "type": "boolean" },
        "isActive": { "type": "boolean" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["growwServiceId", "name", "category", "platform", "providerRate", "displayRate", "isActive"]
    },
    "Order": {
      "title": "Order",
      "description": "SMM service order",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "serviceId": { "type": "string" },
        "serviceName": { "type": "string" },
        "growwOrderId": { "type": "integer" },
        "link": { "type": "string", "format": "uri" },
        "quantity": { "type": "integer" },
        "chargeINR": { "type": "number" },
        "chargeUSD": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "processing", "completed", "partial", "cancelled"] },
        "startCount": { "type": "integer" },
        "remains": { "type": "integer" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "serviceId", "growwOrderId", "link", "quantity", "chargeINR", "status", "createdAt"]
    },
    "Transaction": {
      "title": "Transaction",
      "description": "Wallet transaction record",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "amount": { "type": "number" },
        "type": { "type": "string", "enum": ["deposit", "order_debit", "refund"] },
        "razorpayPaymentId": { "type": "string" },
        "status": { "type": "string", "enum": ["completed", "pending", "failed"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "amount", "type", "status", "createdAt"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "UserProfile",
      "description": "User profiles"
    },
    "services/{serviceId}": {
      "schema": "Service",
      "description": "Available SMM services"
    },
    "orders/{orderId}": {
      "schema": "Order",
      "description": "Service orders"
    },
    "transactions/{txId}": {
      "schema": "Transaction",
      "description": "Wallet transactions"
    }
  }
}
