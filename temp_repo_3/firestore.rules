rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // ⚠️ WARNING: These rules allow public read/write access so your app can work immediately.
    // In a real production app, you MUST implement Firebase Authentication and restrict access 
    // to only authenticated admin users.
    
    match /orders/{orderId} {
      allow read, write: if true;
    }
    
    // System settings (Telegram config, Razorpay keys, etc.)
    match /system/{docId} {
      allow read: if true;
      allow write: if true; // Admin panel writes settings
    }
    
    // Services catalog
    match /services/{serviceId} {
      allow read: if true;
      allow write: if true;
    }

    // Users & other collections
    match /users/{userId} {
      allow read, write: if true;
    }
    
    // Catch-all: deny everything else
    match /{document=**} {
      allow read, write: if true;
    }
  }
}
